{
  "dashboard": {
    "id": null,
    "uid": "quart-bot-main",
    "title": "Quart Bot SaaS Overview",
    "tags": ["quart", "ollama", "saas"],
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(quart_requests_total[1m])",
            "legendFormat": "{{tool}} — {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "P99 Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(quart_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Cache Hit Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "quart_cache_hits_total / (quart_cache_hits_total + quart_cache_misses_total)",
            "legendFormat": "Hit Rate"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Active Requests",
        "type": "stat",
        "targets": [
          {
            "expr": "quart_active_requests",
            "legendFormat": "Active"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8}
      },
      {
        "id": 5,
        "title": "Circuit Breaker States",
        "type": "graph",
        "targets": [
          {
            "expr": "quart_circuit_breaker_state",
            "legendFormat": "{{name}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
      },
      {
        "id": 6,
        "title": "GPU Utilization",
        "type": "graph",
        "targets": [
          {
            "expr": "quart_gpu_utilization",
            "legendFormat": "GPU {{gpu_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
      },
      {
        "id": 7,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(quart_errors_total[1m])",
            "legendFormat": "{{error_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20}
      },
      {
        "id": 8,
        "title": "DLQ Size",
        "type": "stat",
        "targets": [
          {
            "expr": "quart_dlq_size",
            "legendFormat": "Messages"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 20}
      },
      {
        "id": 9,
        "title": "Metric Collection Failures / 5m",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(quart_metric_failures_total[5m])",
            "legendFormat": "failures/sec"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 20},
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          },
          "overrides": []
        }
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "30s"
  }
}
