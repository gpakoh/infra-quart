# ============================================
# infra-quart Environment Variables
# Copy to .env and fill in secrets
# ============================================

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=raguser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rag_vectordb

# --- Cache ---
REDIS_URL=redis://redis:6379/0

# --- LLM ---
OLLAMA_MODEL=gemma3:12b
OLLAMA_URL=http://ollama:11434

# --- Embeddings ---
INFINITY_URL=http://infinity:7997
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- Auth ---
ADMIN_API_KEY=change-me
FEDERATION_SECRET=change-me

# --- Zep (memory) ---
ZEP_API_URL=http://zep:8000
ZEP_API_KEY=change-me

# --- OpenCode Adapter ---
OPENCODE_SERVER_PASSWORD=change-me

# --- RAG Library Service ---
RAG_LIBRARY_PORT=8010
RAG_LIBRARY_URL=http://rag-library-service:8010
RAG_LIBRARY_ENABLED=true

# --- Bot Service (profile: bot) ---
DOCUMENT_API_ENABLED=true
QUART_CORE_URL=http://quart-core:8000
QUART_CORE_TIMEOUT=10
